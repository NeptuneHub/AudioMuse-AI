# .dockerignore

# Git and version control
.git
.gitignore
.gitattributes
.github

# Docker-specific files that shouldn't be in the image
.dockerignore
Dockerfile

# Deployment files
# These are for deploying the container, not for running the code inside it.
# deployment/
# !deployment/**
# !deployment/supervisord.conf
# !deployment/docker-entrypoint.sh
test/

# Student CLAP training (not needed in production)
student_clap/

# macOS and Linux standalone app: source trees (PyInstaller spec / nfpm config,
# vendored redis/pg binaries, assets) and build artifacts. None of it is used by
# the Linux container, so keep it out of the image.
macos/
linux/
build/
dist/

# Python virtual environment and cache
__pycache__/
*.pyc
*.pyo
*.pyd
venv
.venv
env
.env*

# IDE and editor configuration
.vscode/
.idea/

# Documentation, screenshots, and local test files
README.md
docs/
query/
screenshot/
.pytest_cache/
htmlcov/
.coverage
*.log

# Large model files and caches (these are downloaded inside the container)
model/
*.onnx
*.pt
*.pth
*.bin
*.h5
*.pb
CLAMP3/weights_*.pth
CLAMP3/*.npy
.cache/
*.tar.gz
