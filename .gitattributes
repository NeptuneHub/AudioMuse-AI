*.pb filter=lfs diff=lfs merge=lfs -text

# Force LF for files that run inside Linux containers
*.sh text eol=lf
*.py text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.spec text eol=lf
*.bat text eol=lf
*.ps1 text eol=lf
*.wxs text eol=lf
*.md text eol=lf
Dockerfile* text eol=lf

# Force LF for the Linux package's freedesktop/systemd files (parsed on Linux)
*.desktop text eol=lf
*.service text eol=lf
